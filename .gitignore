# Dependencies
# NO trailing slash: `node_modules/` matches directories ONLY. The disk-constraint
# workflow symlinks node_modules into worker worktrees, and a symlink is a FILE —
# so the slashed pattern let `git add -A` commit the symlink as a blob (caught at
# review, 2026-07-16). Slash-less matches both the real directory and the symlink.
node_modules
.pnp/
.pnp.js

# Build output
dist/
build/
.next/
out/
.output/

# Environment
.env
.env.local
.env.*.local

# Claude Code worktrees & local state
.claude/worktrees/
.claude/settings.local.json

# OS / editor
.DS_Store
*.log
.vscode/
.idea/
.vercel
